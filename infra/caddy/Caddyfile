# ════════════════════════════════════════════════════════════════
# Caddy reverse proxy — Onda 4c (TLS público)
#
# Modo dev (default no .env.example):
#   CADDY_GLOBAL = "auto_https off"
#   TLS_SITE     = ":80"
#   → Caddy escuta :80 em HTTP, sem cert. Acessar: http://localhost
#
# Modo prod:
#   CADDY_GLOBAL = "email admin@seu-dominio.com"
#   TLS_SITE     = "seu-dominio.com"
#   → Caddy obtém cert Let's Encrypt automaticamente. Pré-requisitos:
#     - DNS A/AAAA do domain apontando para o IP do host
#     - Portas 80 e 443 acessíveis da internet (firewall, NAT)
#     - .env real preenchido + `docker compose up -d caddy`
#
# Headers de segurança baseline. HSTS deixado comentado — ative apenas
# em prod quando estiver 100% certo do domain (HSTS é sticky no browser).
# ════════════════════════════════════════════════════════════════
{
	{$CADDY_GLOBAL}
}

{$TLS_SITE::80} {
	reverse_proxy app:7000

	encode gzip zstd

	# Headers de segurança (não sobrepõe se app já enviar).
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# HSTS: comentado por segurança. Em prod, descomente DEPOIS de
		# confirmar que o site funciona em HTTPS — HSTS é sticky no browser
		# e errar derruba acesso por meses.
		# Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	}

	log {
		output stdout
		format json
		# Não logar /api/health (ruído)
		level INFO
	}
}
