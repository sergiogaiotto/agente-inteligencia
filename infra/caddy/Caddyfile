# ════════════════════════════════════════════════════════════════
# Caddy reverse proxy — Onda 4c (TLS público)
#
# Modo dev (default no .env.example):
#   CADDY_GLOBAL = "auto_https off"
#   TLS_SITE     = ":80"
#   → Caddy escuta :80 em HTTP, sem cert. Acessar: http://localhost
#
# Modo prod:
#   CADDY_GLOBAL = "email admin@seu-dominio.com"
#   TLS_SITE     = "seu-dominio.com"
#   → Caddy obtém cert Let's Encrypt automaticamente. Pré-requisitos:
#     - DNS A/AAAA do domain apontando para o IP do host
#     - Portas 80 e 443 acessíveis da internet (firewall, NAT)
#     - .env real preenchido + `docker compose up -d caddy`
#
# Headers de segurança baseline. HSTS deixado comentado — ative apenas
# em prod quando estiver 100% certo do domain (HSTS é sticky no browser).
# ════════════════════════════════════════════════════════════════
{
	{$CADDY_GLOBAL}
}

{$TLS_SITE::80} {
	# ─── Observabilidade (profile full) ─────────────────────────────
	# Reverse proxy para Grafana sob /grafana/* (mesma origin → sem CORS
	# nem SSH tunnel). Grafana precisa de GF_SERVER_ROOT_URL e
	# GF_SERVER_SERVE_FROM_SUB_PATH=true (definidos no docker-compose.yml).
	# Sobrevive se grafana estiver down (Caddy retorna 502, browser mostra
	# erro normal — só não derruba o resto da app).
	handle_path /grafana/* {
		reverse_proxy grafana:3000 {
			# Headers que o Grafana usa pra detectar o reverse proxy
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Host {host}
		}
	}

	# Dashboard nativo do Qdrant (opcional, debug).
	handle_path /qdrant/* {
		reverse_proxy qdrant:6333
	}

	# Loki API (debug — útil pra rodar curl direto sem expor porta).
	# Acesso protegido pela mesma camada do app (cookie/api key).
	handle_path /loki/* {
		reverse_proxy loki:3100
	}

	# Tudo o mais vai pra app FastAPI.
	reverse_proxy app:7000

	encode gzip zstd

	# Headers de segurança (não sobrepõe se app já enviar).
	header {
		X-Content-Type-Options nosniff
		# X-Frame-Options removido aqui porque Grafana SOB /grafana/* já manda
		# o seu próprio (controlado por GF_SECURITY_ALLOW_EMBEDDING). Para
		# rotas da app, o backend define Content-Security-Policy frame-ancestors
		# se precisar.
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		# HSTS: comentado por segurança. Em prod, descomente DEPOIS de
		# confirmar que o site funciona em HTTPS — HSTS é sticky no browser
		# e errar derruba acesso por meses.
		# Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
	}

	log {
		output stdout
		format json
		# Não logar /api/health (ruído)
		level INFO
	}
}
