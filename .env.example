# ═══════════════════════════════════════════════════════════════
# Maestro — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha. NUNCA commit `.env`.
# ═══════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────
APP_NAME=Maestro
APP_ENV=production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=7000
APP_PORT_HOST=7000
SECRET_KEY=troque-isto-por-uma-chave-aleatoria-de-64-caracteres

# ─── PostgreSQL ────────────────────────────────────────────────
# Em docker-compose, postgres é alcançado pelo nome do service.
# Em produção VPS, use senhas fortes geradas com `openssl rand -hex 24`.
POSTGRES_USER=agente
POSTGRES_PASSWORD=troque-esta-senha-em-producao
POSTGRES_DB=agente_inteligencia
DATABASE_URL=postgresql://agente:troque-esta-senha-em-producao@postgres:5432/agente_inteligencia
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis (cache de contexto + rate-limit Onda 1) ─────────────
REDIS_URL=redis://redis:6379/0

# ─── Vector DB (RAG) ───────────────────────────────────────────
# Onda Q (2026-05-30): backend único = pgvector (Postgres com extensão
# `vector` em evidence_chunks.embedding via /api/v1/evidence/reindex).
# Transação atômica chunk+vetor (impossível ficar divergente), 1 sistema
# só, backup pg_dump cobre tudo. Requer imagem pgvector/pgvector:pg16.
#
# Qdrant foi REMOVIDO. Variáveis RAG_VECTOR_BACKEND, QDRANT_URL,
# QDRANT_API_KEY, QDRANT_COLLECTION descontinuadas. Se setadas, ignoradas.

# ─── RAG v2 (Onda 3 — busca híbrida BM25+vetorial) ────────────
# Toggle global. False → retriever cai no fallback antigo (busca textual em metadados).
RAG_V2_ENABLED=true
RAG_CHUNK_SIZE_TOKENS=500
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_TOP_N_VECTOR=20
RAG_TOP_N_BM25=20
RAG_RRF_K=60
# LLM-as-reranker: +500ms latência, +$0.0005/query, qualidade superior.
# False = heurística de overlap (mais rápido, menos preciso).
RAG_RERANK_WITH_LLM=true

# ─── LLM provider primário ─────────────────────────────────────
# azure | openai | maritaca | ollama
DEFAULT_LLM_PROVIDER=azure

# ─── Azure OpenAI (PROVEDOR PRINCIPAL) ─────────────────────────
# Obtenha em portal.azure.com → seu recurso OpenAI → Keys and Endpoint.
# O `chat_deployment` é o NOME DO DEPLOYMENT criado no Azure Studio
# (não é o nome do modelo).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# ─── OpenAI público — REMOVIDO (Onda 7 Wave 5) ─────────────────
# OPENAI_API_KEY foi descontinuada. Provider "openai" agora é alias
# de Azure OpenAI no llm_providers.get_provider — toda chamada usa
# AZURE_OPENAI_API_KEY acima. Modelos GPT-4o/4.1/o1/etc continuam
# disponíveis via Azure (são os mesmos modelos hospedados lá).

# ─── Maritaca AI ───────────────────────────────────────────────
MARITACA_API_KEY=
MARITACA_API_URL=https://chat.maritaca.ai/api
MARITACA_MODEL=sabia-3

# ─── Ollama (LLM local) ────────────────────────────────────────
OLLAMA_API_URL=http://ollama:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1

# ─── LangFuse (observabilidade SaaS — opcional) ────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Observabilidade self-hosted (Onda 2) ──────────────────────
# Tracing distribuído via OpenTelemetry → Tempo + correlação com logs no Loki,
# tudo visualizado em Grafana. Ativa o stack inteiro com:
#   docker compose --profile full up -d
# ⚠ Se ligar OTEL_ENABLED=true SEM subir o profile full, o app continua
# funcionando (graceful degradation), mas o exporter polui o log com
# WARNING/ERROR "UNAVAILABLE" a cada poucos segundos tentando bater em tempo:4317.
# Em VPS com pouca RAM (Hostinger etc.) prefira deixar false.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agente-inteligencia
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_TRACES_SAMPLER=parentbased_always_on
LOKI_ENDPOINT=http://loki:3100

# ─── DeepAgent Harness ─────────────────────────────────────────
DEEPAGENT_ENABLED=true
DEEPAGENT_MAX_ITERATIONS=25
DEEPAGENT_TIMEOUT=120

# ─── TLS público (Onda 4c — Caddy reverse proxy) ───────────────
# Caddy entra em paralelo com a porta :7000 do app (que continua aberta).
# Para acessar via Caddy: http://localhost:${TLS_HTTP_PORT_HOST}
#
# DEFAULT LOCAL (este arquivo) usa 8080/8443 — funciona em Windows/Mac/Linux
# sem fricção. Em Windows a 80 costuma estar reservada (Hyper-V/IIS/WinNAT) —
# para diagnosticar: `netsh int ipv4 show excludedportrange protocol=tcp`.
# Em Linux precisa privilégio para bindar < 1024 (sudo ou setcap).
#
# PARA PRODUÇÃO (deploy real com Let's Encrypt):
#   TLS_HTTP_PORT_HOST=80
#   TLS_HTTPS_PORT_HOST=443
#   TLS_SITE=meudominio.com
#   CADDY_GLOBAL=email admin@meudominio.com    (remova 'auto_https off')
TLS_HTTP_PORT_HOST=8080
TLS_HTTPS_PORT_HOST=8443
TLS_SITE=:80
CADDY_GLOBAL=auto_https off

# ─── Observabilidade UIs (links em /infra) ─────────────────────
# Quando rodando atrás de Caddy (prod ou VPS), as UIs do Grafana e
# Qdrant ficam DENTRO do mesmo domínio do app via reverse_proxy.
# Caddy resolve /grafana/* internamente — você não precisa
# de SSH tunnel nem expor portas extras.
#
# Defaults (recomendado, funciona com Caddy):
#   GRAFANA_UI_URL=/grafana/
#
# Dev local SEM Caddy (uvicorn direto + docker-compose):
#   GRAFANA_UI_URL=http://localhost:3000
#   GRAFANA_ROOT_URL=http://localhost:3000
#   GRAFANA_SUB_PATH=false
#
# Onda Q (2026-05-30): QDRANT_UI_URL removida (Qdrant deletado).
GRAFANA_UI_URL=/grafana/
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Anonymous viewer (Viewer-only) facilita o iframe da /infra. Em prod com
# dados sensíveis nos dashboards, troque para false e configure auth.
GRAFANA_ANON_ENABLED=true
# IMPORTANTE em VPS: Grafana NÃO substitui %(domain)s/%(protocol)s quando o
# root_url vem de env var (só funciona em grafana.ini). Por isso PRECISA
# setar o domínio público completo aqui, senão Grafana redireciona pra
# http://localhost:3000/ ao fazer login (Caddy proxy → Grafana → "Location:
# http://localhost:3000/grafana/login").
#
# Dev local (Caddy na 8080):
#   GRAFANA_ROOT_URL=http://localhost:8080/grafana/  ← default
#
# VPS HTTP (sem TLS) com domínio:
#   GRAFANA_ROOT_URL=http://meudominio.com:8080/grafana/
#
# VPS HTTPS com TLS (Caddy + Let's Encrypt):
#   GRAFANA_ROOT_URL=https://meudominio.com/grafana/
#   TLS_HTTP_PORT_HOST=80  TLS_HTTPS_PORT_HOST=443  TLS_SITE=meudominio.com
#
# Acesso direto na porta 3000 (sem Caddy):
#   GRAFANA_ROOT_URL=http://localhost:3000/  + GRAFANA_SUB_PATH=false
GRAFANA_ROOT_URL=http://localhost:8080/grafana/
GRAFANA_SUB_PATH=true

# ─── Verifier v2 (judge multi-dimensional) ─────────────────────
# Promove o EvidenceChecker a 1ª classe: 4 dimensões (factuality, completeness,
# tone_adherence, safety) + ContractValidator determinístico. Default OFF para
# preservar comportamento legacy (Onda 0). Ligar quando estiver pronto para usar.
VERIFIER_V2_ENABLED=true
VERIFIER_JUDGE_MODEL=azure/gpt-4o
VERIFIER_FACTUALITY_THRESHOLD=3.0
VERIFIER_COMPLETENESS_THRESHOLD=3.0
VERIFIER_TONE_THRESHOLD=3.0
VERIFIER_MAX_TOKENS=800

# ─── Policy Engine (Onda 4a — OPA) ─────────────────────────────
# Quando ENABLED=true, PolicyCheck e tool_invocation consultam o OPA para
# decidir allow/deny baseado em políticas Rego (infra/opa/policies/*.rego).
# Failsafe-open=true: se OPA offline, allow=true com warning+audit. Em prod
# com dados sensíveis, trocar para failsafe-closed (false).
OPA_ENABLED=false
OPA_URL=http://opa:8181
OPA_FAILSAFE_OPEN=true
OPA_TIMEOUT_SECONDS=2.0

# ─── Persistência de dados (CRÍTICO em VPS) ────────────────────
# Por default, dados ficam em volumes Docker nomeados (postgres_data, etc.)
# que vivem em /var/lib/docker/volumes/. Funciona perfeito em dev local.
#
# ⚠ EM VPS DA HOSTINGER (e provedores similares): volumes Docker são
# APAGADOS no Redeploy automático — você perde TUDO (agentes, conversas,
# uploads, audit log, etc.). A defesa é apontar pra um path ABSOLUTO no
# host, fora do diretório do projeto que a Hostinger gerencia.
#
# Setup uma vez via SSH no VPS:
#   sudo mkdir -p /var/lib/agente-persist/{postgres,redis,app}
#   sudo chown -R 999:999 /var/lib/agente-persist/postgres   # uid postgres
#   sudo chown -R 999:999 /var/lib/agente-persist/redis      # uid redis
#   sudo chown -R 1000:1000 /var/lib/agente-persist/app
#
# Depois descomente as 3 linhas abaixo e faça Redeploy:
# PG_DATA_DIR=/var/lib/agente-persist/postgres
# REDIS_DATA_DIR=/var/lib/agente-persist/redis
# APP_DATA_DIR=/var/lib/agente-persist/app
# (Onda Q 2026-05-30: QDRANT_DATA_DIR removido — Qdrant deletado.)
