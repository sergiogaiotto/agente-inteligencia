# ============================================
# AgenteInteligência-AI — Variáveis de Ambiente
# ============================================

# --- App ---
APP_NAME=AgenteInteligência-AI
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/agente_inteligencia.db

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# --- Maritaca AI ---
MARITACA_API_KEY=your-maritaca-key-here
MARITACA_API_URL=https://chat.maritaca.ai/api
MARITACA_MODEL=sabia-3

# --- LangFuse (Observabilidade) ---
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- DeepAgent Harness ---
DEEPAGENT_ENABLED=true
DEEPAGENT_MAX_ITERATIONS=25
DEEPAGENT_TIMEOUT=120
