# ═══════════════════════════════════════════════════════════════
# AgenteInteligência-AI — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha. NUNCA commit `.env`.
# ═══════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────
APP_NAME=AgenteInteligência-AI
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=7000
APP_PORT_HOST=7000
SECRET_KEY=troque-isto-por-uma-chave-aleatoria-de-64-caracteres

# ─── PostgreSQL ────────────────────────────────────────────────
# Em docker-compose, postgres é alcançado pelo nome do service.
# Em produção VPS, use senhas fortes geradas com `openssl rand -hex 24`.
POSTGRES_USER=agente
POSTGRES_PASSWORD=troque-esta-senha-em-producao
POSTGRES_DB=agente_inteligencia
DATABASE_URL=postgresql://agente:troque-esta-senha-em-producao@postgres:5432/agente_inteligencia
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis (cache de contexto + rate-limit Onda 1) ─────────────
REDIS_URL=redis://redis:6379/0

# ─── Qdrant (Vector DB para RAG — Onda 3) ──────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agente_evidence

# ─── RAG v2 (Onda 3 — busca híbrida BM25+vetorial) ────────────
# Toggle global. False → retriever cai no fallback antigo (busca textual em metadados).
RAG_V2_ENABLED=true
RAG_CHUNK_SIZE_TOKENS=500
RAG_CHUNK_OVERLAP_TOKENS=50
RAG_TOP_N_VECTOR=20
RAG_TOP_N_BM25=20
RAG_RRF_K=60
# LLM-as-reranker: +500ms latência, +$0.0005/query, qualidade superior.
# False = heurística de overlap (mais rápido, menos preciso).
RAG_RERANK_WITH_LLM=true

# ─── LLM provider primário ─────────────────────────────────────
# azure | openai | maritaca | ollama
DEFAULT_LLM_PROVIDER=azure

# ─── Azure OpenAI (PROVEDOR PRINCIPAL) ─────────────────────────
# Obtenha em portal.azure.com → seu recurso OpenAI → Keys and Endpoint.
# O `chat_deployment` é o NOME DO DEPLOYMENT criado no Azure Studio
# (não é o nome do modelo).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# ─── OpenAI (fallback público) ─────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Maritaca AI ───────────────────────────────────────────────
MARITACA_API_KEY=
MARITACA_API_URL=https://chat.maritaca.ai/api
MARITACA_MODEL=sabia-3

# ─── Ollama (LLM local) ────────────────────────────────────────
OLLAMA_API_URL=http://ollama:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1

# ─── LangFuse (observabilidade SaaS — opcional) ────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Observabilidade self-hosted (Onda 2) ──────────────────────
# Tracing distribuído via OpenTelemetry → Tempo + correlação com logs no Loki,
# tudo visualizado em Grafana. Ativa o stack inteiro com:
#   docker compose --profile full up -d
# Sem o profile, mesmo com OTEL_ENABLED=true o app só falhará silenciosamente
# em conectar (graceful degradation — pipeline normal continua).
OTEL_ENABLED=false
OTEL_SERVICE_NAME=agente-inteligencia
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_TRACES_SAMPLER=parentbased_always_on
LOKI_ENDPOINT=http://loki:3100

# ─── DeepAgent Harness ─────────────────────────────────────────
DEEPAGENT_ENABLED=true
DEEPAGENT_MAX_ITERATIONS=25
DEEPAGENT_TIMEOUT=120

# ─── TLS público (Onda 4c — Caddy reverse proxy) ───────────────
# Caddy entra em paralelo com a porta :7000 do app (que continua aberta).
# Para acessar via Caddy: http://localhost:${TLS_HTTP_PORT_HOST}
#
# DEFAULT LOCAL (este arquivo) usa 8080/8443 — funciona em Windows/Mac/Linux
# sem fricção. Em Windows a 80 costuma estar reservada (Hyper-V/IIS/WinNAT) —
# para diagnosticar: `netsh int ipv4 show excludedportrange protocol=tcp`.
# Em Linux precisa privilégio para bindar < 1024 (sudo ou setcap).
#
# PARA PRODUÇÃO (deploy real com Let's Encrypt):
#   TLS_HTTP_PORT_HOST=80
#   TLS_HTTPS_PORT_HOST=443
#   TLS_SITE=meudominio.com
#   CADDY_GLOBAL=email admin@meudominio.com    (remova 'auto_https off')
TLS_HTTP_PORT_HOST=8080
TLS_HTTPS_PORT_HOST=8443
TLS_SITE=:8080
CADDY_GLOBAL=auto_https off

# ─── Verifier v2 (judge multi-dimensional) ─────────────────────
# Promove o EvidenceChecker a 1ª classe: 4 dimensões (factuality, completeness,
# tone_adherence, safety) + ContractValidator determinístico. Default OFF para
# preservar comportamento legacy (Onda 0). Ligar quando estiver pronto para usar.
VERIFIER_V2_ENABLED=false
VERIFIER_JUDGE_MODEL=azure/gpt-4o
VERIFIER_FACTUALITY_THRESHOLD=3.0
VERIFIER_COMPLETENESS_THRESHOLD=3.0
VERIFIER_TONE_THRESHOLD=3.0
VERIFIER_MAX_TOKENS=800

# ─── Policy Engine (Onda 4a — OPA) ─────────────────────────────
# Quando ENABLED=true, PolicyCheck e tool_invocation consultam o OPA para
# decidir allow/deny baseado em políticas Rego (infra/opa/policies/*.rego).
# Failsafe-open=true: se OPA offline, allow=true com warning+audit. Em prod
# com dados sensíveis, trocar para failsafe-closed (false).
OPA_ENABLED=false
OPA_URL=http://opa:8181
OPA_FAILSAFE_OPEN=true
OPA_TIMEOUT_SECONDS=2.0

# ─── AI Gateway (Onda 4b — LiteLLM proxy) ──────────────────────
# Quando ENABLED=true, providers chamam LiteLLM em vez do upstream direto.
# Centraliza rate-limit, fallback automático, logging, custos.
# A master_key precisa estar setada (openssl rand -hex 24) ou o gateway recusa.
LLM_GATEWAY_ENABLED=false
LLM_GATEWAY_URL=http://litellm:4000
LLM_GATEWAY_MASTER_KEY=
LLM_GATEWAY_FALLBACK_TO_DIRECT=true
